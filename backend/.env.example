# PostgreSQL connection string from Neon, Supabase, or any managed provider
# Example (Neon): postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
# Example (Supabase): postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
DATABASE_URL=""

PORT=5050

# Your deployed frontend URL — used for CORS and Socket.io origin whitelisting
# Example: https://yourdomain.com  or  https://linklabour.vercel.app
FRONTEND_URL="http://localhost:5173"

# Google OAuth Client ID (optional — leave blank to use simulated Google login)
GOOGLE_CLIENT_ID=""
